## Benchmark: iterative fibonacci + tight loop sum

define fibonacci(n: int) -> int:
	if n <= 1:
		return n
	a = 0
	b = 1
	for i in range(2, n + 1):
		temp = b
		b = a + b
		a = temp
	return b

## Run fibonacci many times
total = 0
for i in range(0, 1000000):
	total = total + fibonacci(30)

print(total)
